{
  "extends": ["stylelint-config-standard"],
  "overrides": [
    {
      "files": ["**/*.js", "**/*.jsx", "**/*.ts", "**/*.tsx"],
      "customSyntax": "postcss-styled-syntax"
    }
  ],
  "rules": {
    "font-family-no-missing-generic-family-keyword": null,
    "no-descending-specificity": null,
    "function-no-unknown": [
      true,
      {
        "ignoreFunctions": ["oklch", "theme"]
      }
    ]
  }
}